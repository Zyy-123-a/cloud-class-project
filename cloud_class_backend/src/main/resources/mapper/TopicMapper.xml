<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wangguo.mapper.TopicMapper">
    <!-- 批量更新排序已注解实现，无需xml -->
    <insert id="insert" parameterType="Topic">
        INSERT INTO topic(cid,uid,role,title,content,is_anonym,is_top,is_essence,create_time,update_time,author_name)
        VALUES(#{cid},#{uid},#{role},#{title},#{content},#{isAnonym},#{isTop},#{isEssence},#{createTime},#{updateTime},#{authorName})
    </insert>
    <select id="selectById" resultType="Topic">
        SELECT * FROM topic WHERE tid = #{tid}
    </select>
</mapper>